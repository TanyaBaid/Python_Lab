CODE
import pandas as pd
import matplotlib.pyplot as plt

data = {
    "Name": ["Tanya", "Shivani", "Jiya", "Udita"],
    "Marks": [85, 92, 78, 88]
}

df = pd.DataFrame(data)

print("DataFrame:\n", df)
plt.bar(df["Name"], df["Marks"])
plt.xlabel("Students")
plt.ylabel("Marks")
plt.title("Students Marks Graph")

plt.show()


