import numpy as np
import pandas as pd

print("NumPy Operations:")

arr = np.array([10, 20, 30, 40, 50])

print("Array:", arr)
print("Mean:", np.mean(arr))
print("Maximum:", np.max(arr))
print("Array + 5:", arr + 5)

print("\nPandas Operations:")

data = {
    "Name": ["Tanya", "Shivani", "Jiya", "Udita"],
    "Marks": [85, 92, 78, 88]
}
df = pd.DataFrame(data)
print("DataFrame:\n", df)
print("\nStudents scoring above 90:\n", df[df["Marks"] > 90])

